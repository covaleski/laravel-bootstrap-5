{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "covaleski/laravel-bootstrap-5",
    "type": "library",
    "description": "Bootstrap 5 components for Laravel.",
    "keywords": [
        "laravel",
        "framework",
        "bootstrap"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Rafael Covaleski",
            "email": "covaleski23@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "twbs/bootstrap": "5.3.8"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/tinker": "^3.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "orchestra/testbench": "^11.1",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "Covaleski\\LaravelBootstrap5\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "ci": [
            "composer install -q --no-ansi --no-interaction --no-scripts --no-progress --prefer-dist",
            "@test"
        ],
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "rebuild": [
            "@post-autoload-dump",
            "@build"
        ],
        "retest": [
            "@clear",
            "@test"
        ],
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "lint": "@php vendor/bin/pint --preset psr12 --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "@php vendor/bin/phpunit -c ./ --color"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Covaleski\\LaravelBootstrap5\\Providers\\PackageServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
